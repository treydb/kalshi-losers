# Copy to .deploy.env in the repo root and edit before running ./deploy.sh --bootstrap
#
# Public URL visitors use (must match Cloudflare tunnel hostname for CORS).
PUBLIC_URL=https://losers.example.com

# Port Caddy listens on (cloudflared should point here).
CADDY_PORT=8080

# Timezone for the daily leaderboard bucket.
LOCAL_TZ=America/Denver

# Set to 1 to apt-install git, python3-venv, nodejs, npm, and caddy.
INSTALL_DEPS=1
